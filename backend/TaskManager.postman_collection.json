{
  "info": {
    "name": "Task Manager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4444"
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "taskId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Category",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has _id', () => pm.expect(pm.response.json()).to.have.property('_id'));",
                  "pm.collectionVariables.set('categoryId', pm.response.json()._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"In Progress\",\n  \"color\": \"#2E74B5\"\n}"
            }
          }
        },
        {
          "name": "Create Category – invalid (no name)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('invalidDtoIn', () => pm.expect(pm.response.json().message).to.eql('invalidDtoIn'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"color\": \"#2E74B5\"\n}"
            }
          }
        },
        {
          "name": "Create Category – invalid (bad hex)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('invalidDtoIn', () => pm.expect(pm.response.json().message).to.eql('invalidDtoIn'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"color\": \"notacolor\"\n}"
            }
          }
        },
        {
          "name": "Get All Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Get Category By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correct id', () => pm.expect(pm.response.json()._id).to.eql(pm.collectionVariables.get('categoryId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Get Category By Id – not found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/000000000000000000000000"
          }
        },
        {
          "name": "Update Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => pm.expect(pm.response.json().name).to.eql('Done'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Done\",\n  \"color\": \"#2E7A3C\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Deleted message', () => pm.expect(pm.response.json().message).to.eql('Category deleted'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Task",
      "item": [
        {
          "name": "Setup – Create Category for Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('categoryId', pm.response.json()._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"To Do\",\n  \"color\": \"#F0A500\"\n}"
            }
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has _id', () => pm.expect(pm.response.json()).to.have.property('_id'));",
                  "pm.test('Status is pending', () => pm.expect(pm.response.json().status).to.eql('pending'));",
                  "pm.collectionVariables.set('taskId', pm.response.json()._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Design homepage\",\n  \"description\": \"Create wireframes\",\n  \"deadline\": \"2026-04-01\",\n  \"category_id\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Create Task – invalid (no name)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('invalidDtoIn', () => pm.expect(pm.response.json().message).to.eql('invalidDtoIn'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Create Task – invalid (bad category_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('invalidDtoIn', () => pm.expect(pm.response.json().message).to.eql('invalidDtoIn'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test task\",\n  \"category_id\": \"notanid\"\n}"
            }
          }
        },
        {
          "name": "Create Task – invalid (bad status)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('invalidDtoIn', () => pm.expect(pm.response.json().message).to.eql('invalidDtoIn'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test task\",\n  \"status\": \"invalid_status\",\n  \"category_id\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Get All Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Get All Tasks filtered by category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks?category_id={{categoryId}}",
              "query": [{ "key": "category_id", "value": "{{categoryId}}" }]
            }
          }
        },
        {
          "name": "Get Task By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correct id', () => pm.expect(pm.response.json()._id).to.eql(pm.collectionVariables.get('taskId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        },
        {
          "name": "Get Task By Id – not found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tasks/000000000000000000000000"
          }
        },
        {
          "name": "Update Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status updated to done', () => pm.expect(pm.response.json().status).to.eql('done'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Design homepage\",\n  \"status\": \"done\",\n  \"category_id\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Deleted message', () => pm.expect(pm.response.json().message).to.eql('Task deleted'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        }
      ]
    }
  ]
}